@model StockPortfolio.Models.PortfolioIndexViewModel
@{
    ViewData["Title"] = "股票資產庫存";
}

<h1 class="text-2xl font-bold text-white mb-6">股票資產庫存</h1>

@if (TempData["AddError"] != null)
{
    <div class="glass bg-red-500/20 border-red-400/30 text-red-200 rounded-xl p-4 mb-4 flex justify-between items-start"
         role="alert">
        <span>@TempData["AddError"]</span>
        <button type="button" class="ml-4 text-red-300 hover:text-red-100 text-xl leading-none"
                data-dismiss-alert aria-label="關閉"><i class="fa-solid fa-xmark"></i></button>
    </div>
}

<!-- 新增持股 -->
<div class="glass rounded-xl mb-6">
    <div class="px-4 py-3 border-b border-white/15 font-semibold text-white/90">新增持股</div>
    <div class="p-4">
        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 items-end">
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-1" for="new-symbol">股票代號</label>
                    <input id="new-symbol" name="NewHolding.Symbol"
                           class="glass-input rounded-md"
                           placeholder="例：2330" autocomplete="off" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-1" for="new-shares">股數</label>
                    <input id="new-shares" name="NewHolding.Shares" type="number" step="1" min="1"
                           class="glass-input rounded-md"
                           placeholder="例：1000" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-1" for="new-price">購入成本（每股）</label>
                    <input id="new-price" name="NewHolding.PurchasePrice" type="number" step="0.01" min="0.01"
                           class="glass-input rounded-md"
                           placeholder="例：500.00" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-white/70 mb-1" for="new-date">購入日期</label>
                    <input id="new-date" name="NewHolding.PurchaseDate" type="date"
                           class="glass-input rounded-md"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div>
                    <button type="submit"
                            class="w-full bg-blue-500/70 hover:bg-blue-400/80 backdrop-blur-sm text-white font-medium text-sm px-4 py-2 rounded-md border border-blue-400/30 focus:outline-none focus:ring-2 focus:ring-blue-400/50 transition-colors">
                        新增
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Holdings.Any())
{
    <div class="glass rounded-xl text-center text-white/50 py-16 border-dashed">
        <p class="text-lg mb-1">尚未新增任何持股</p>
        <p class="text-sm">使用上方表單輸入股票代號、股數與購入成本</p>
    </div>
}
else
{
    <!-- 資產摘要 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="glass rounded-xl p-4 text-center">
            <div class="text-white/60 text-sm mb-1">總成本</div>
            <div class="text-xl font-semibold text-white">@Model.TotalCost.ToString("N0")</div>
            <div class="text-white/50 text-sm">元</div>
        </div>
        <div class="glass rounded-xl p-4 text-center">
            <div class="text-white/60 text-sm mb-1">現值</div>
            @if (Model.HasAnyPrice)
            {
                <div class="text-xl font-semibold text-white">@Model.TotalCurrentValue.ToString("N0")</div>
                <div class="text-white/50 text-sm">元</div>
            }
            else
            {
                <div class="text-white/30 text-xl">-</div>
            }
        </div>
        <div class="glass rounded-xl p-4 text-center">
            <div class="text-white/60 text-sm mb-1">總損益</div>
            @if (Model.HasAnyPrice)
            {
                <div class="text-xl @(Model.TotalPnL >= 0 ? "tw-gain" : "tw-loss")">
                    @(Model.TotalPnL >= 0 ? "+" : "")@Model.TotalPnL.ToString("N0")
                </div>
                <div class="text-white/50 text-sm">元</div>
            }
            else
            {
                <div class="text-white/30 text-xl">-</div>
            }
        </div>
        <div class="glass rounded-xl p-4 text-center">
            <div class="text-white/60 text-sm mb-1">報酬率</div>
            @if (Model.HasAnyPrice)
            {
                <div class="text-xl @(Model.TotalPnLPercent >= 0 ? "tw-gain" : "tw-loss")">
                    @(Model.TotalPnLPercent >= 0 ? "+" : "")@Model.TotalPnLPercent.ToString("F2")%
                </div>
            }
            else
            {
                <div class="text-white/30 text-xl">-</div>
            }
        </div>
    </div>

    <!-- 持股明細 -->
    <div class="glass rounded-xl">
        <div class="px-4 py-3 border-b border-white/15 flex justify-between items-center">
            <span class="font-semibold text-white/90">持股明細</span>
            <a asp-action="Index"
               class="text-sm border border-white/25 text-white/70 rounded px-3 py-1.5 hover:bg-white/10 transition-colors">
                重新整理報價
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="border-b border-white/10">
                        <th scope="col" class="px-4 py-3 text-left font-medium text-white/60 whitespace-nowrap">代號</th>
                        <th scope="col" class="px-4 py-3 text-left font-medium text-white/60">名稱</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">股數</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">成本/股</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">總成本</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">現在股價</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">現值</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">損益</th>
                        <th scope="col" class="px-4 py-3 text-right font-medium text-white/60 whitespace-nowrap">報酬率</th>
                        <th scope="col" class="px-4 py-3"></th>
                    </tr>
                </thead>
                @foreach (var group in Model.GroupedHoldings)
                {
                    var groupId = "grp-" + group.Symbol;
                    <tbody>
                        <tr class="border-b border-white/10 cursor-pointer hover:bg-white/5 font-medium text-white/90 transition-colors"
                            data-collapse-target="@groupId" aria-expanded="false">
                            <td class="px-4 py-3">
                                <i class="fa-solid fa-chevron-right collapse-icon mr-1 text-white/50" aria-hidden="true"></i>
                                @group.Symbol
                                @if (group.Holdings.Count > 1)
                                {
                                    <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-medium bg-white/15 text-white/60">@group.Holdings.Count 筆</span>
                                }
                            </td>
                            <td class="px-4 py-3">@group.Name</td>
                            <td class="px-4 py-3 text-right">@group.TotalShares.ToString("N0")</td>
                            <td class="px-4 py-3 text-right">@group.AvgPurchasePrice.ToString("N2")</td>
                            <td class="px-4 py-3 text-right">@group.TotalCost.ToString("N0")</td>
                            <td class="px-4 py-3 text-right">
                                @if (group.CurrentPrice.HasValue)
                                {
                                    @group.CurrentPrice.Value.ToString("N2")
                                }
                                else
                                {
                                    <span class="text-white/30 text-xs" title="@group.ErrorMessage">無法取得</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right">
                                @if (group.CurrentValue.HasValue)
                                {
                                    @group.CurrentValue.Value.ToString("N0")
                                }
                                else
                                {
                                    <span class="text-white/30">-</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right">
                                @if (group.PnL.HasValue)
                                {
                                    <span class="@(group.PnL >= 0 ? "tw-gain" : "tw-loss")">
                                        @(group.PnL >= 0 ? "+" : "")@group.PnL.Value.ToString("N0")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-white/30">-</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right">
                                @if (group.PnLPercent.HasValue)
                                {
                                    <span class="@(group.PnLPercent >= 0 ? "tw-gain" : "tw-loss")">
                                        @(group.PnLPercent >= 0 ? "+" : "")@group.PnLPercent.Value.ToString("F2")%
                                    </span>
                                }
                                else
                                {
                                    <span class="text-white/30">-</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a asp-action="Chart" asp-route-symbol="@group.Symbol"
                                   asp-route-purchasePrice="@group.AvgPurchasePrice"
                                   class="js-no-bubble text-xs border border-white/25 text-white/70 rounded px-2 py-1 hover:bg-white/10 transition-colors whitespace-nowrap">
                                    走勢圖
                                </a>
                            </td>
                        </tr>
                    </tbody>
                    <tbody id="@groupId" hidden>
                        @foreach (var h in group.Holdings)
                        {
                            <tr class="border-b border-white/5 bg-black/10 text-white/55">
                                <td class="px-4 py-2.5 pl-8">@h.PurchaseDate.ToString("yyyy/MM/dd")</td>
                                <td class="px-4 py-2.5"></td>
                                <td class="px-4 py-2.5 text-right">@h.Shares.ToString("N0")</td>
                                <td class="px-4 py-2.5 text-right">@h.PurchasePrice.ToString("N2")</td>
                                <td class="px-4 py-2.5 text-right">@h.TotalCost.ToString("N0")</td>
                                <td class="px-4 py-2.5"></td>
                                <td class="px-4 py-2.5 text-right">
                                    @if (h.CurrentValue.HasValue)
                                    {
                                        @h.CurrentValue.Value.ToString("N0")
                                    }
                                    else
                                    {
                                        <span class="text-white/25">-</span>
                                    }
                                </td>
                                <td class="px-4 py-2.5 text-right">
                                    @if (h.PnL.HasValue)
                                    {
                                        <span class="@(h.PnL >= 0 ? "tw-gain" : "tw-loss")">
                                            @(h.PnL >= 0 ? "+" : "")@h.PnL.Value.ToString("N0")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-white/25">-</span>
                                    }
                                </td>
                                <td class="px-4 py-2.5 text-right">
                                    @if (h.PnLPercent.HasValue)
                                    {
                                        <span class="@(h.PnLPercent >= 0 ? "tw-gain" : "tw-loss")">
                                            @(h.PnLPercent >= 0 ? "+" : "")@h.PnLPercent.Value.ToString("F2")%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-white/25">-</span>
                                    }
                                </td>
                                <td class="px-4 py-2.5 text-right">
                                    <form asp-action="Delete" method="post" class="inline"
                                          data-confirm="確定要刪除 @h.Symbol (@h.PurchaseDate.ToString("yyyy/MM/dd")) 的持股紀錄？">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@h.Id" />
                                        <button type="submit"
                                                class="text-xs border border-red-400/35 text-red-400 rounded px-2 py-1 hover:bg-red-400/10 transition-colors whitespace-nowrap">
                                            刪除
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                }
            </table>
        </div>
    </div>
}
