@model StockPortfolio.Models.PortfolioIndexViewModel
@{
    ViewData["Title"] = "股票資產庫存";
}

<h2 class="mb-4">股票資產庫存</h2>

@if (TempData["AddError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["AddError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 新增持股 -->
<div class="card mb-4 shadow-sm">
    <div class="card-header fw-semibold">新增持股</div>
    <div class="card-body">
        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">股票代號</label>
                    <input name="NewHolding.Symbol" class="form-control" placeholder="例：2330" autocomplete="off" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">股數</label>
                    <input name="NewHolding.Shares" type="number" step="1" min="1" class="form-control" placeholder="例：1000" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">購入成本（每股）</label>
                    <input name="NewHolding.PurchasePrice" type="number" step="0.01" min="0.01" class="form-control" placeholder="例：500.00" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">購入日期</label>
                    <input name="NewHolding.PurchaseDate" type="date" class="form-control"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3 col-lg-2">
                    <button type="submit" class="btn btn-primary w-100">新增</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Holdings.Any())
{
    <div class="text-center text-muted py-5 border rounded">
        <p class="fs-5 mb-1">尚未新增任何持股</p>
        <p class="small">使用上方表單輸入股票代號、股數與購入成本</p>
    </div>
}
else
{
    <!-- 資產摘要 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">總成本</div>
                    <div class="fs-5 fw-semibold">@Model.TotalCost.ToString("N0")</div>
                    <div class="text-muted small">元</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">現值</div>
                    @if (Model.HasAnyPrice)
                    {
                        <div class="fs-5 fw-semibold">@Model.TotalCurrentValue.ToString("N0")</div>
                        <div class="text-muted small">元</div>
                    }
                    else
                    {
                        <div class="text-muted">-</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">總損益</div>
                    @if (Model.HasAnyPrice)
                    {
                        <div class="fs-5 fw-semibold @(Model.TotalPnL >= 0 ? "tw-gain" : "tw-loss")">
                            @(Model.TotalPnL >= 0 ? "+" : "")@Model.TotalPnL.ToString("N0")
                        </div>
                        <div class="text-muted small">元</div>
                    }
                    else
                    {
                        <div class="text-muted">-</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="text-muted small mb-1">報酬率</div>
                    @if (Model.HasAnyPrice)
                    {
                        <div class="fs-5 fw-semibold @(Model.TotalPnLPercent >= 0 ? "tw-gain" : "tw-loss")">
                            @(Model.TotalPnLPercent >= 0 ? "+" : "")@Model.TotalPnLPercent.ToString("F2")%
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">-</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 持股明細 -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">持股明細</span>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">重新整理報價</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>代號</th>
                            <th>名稱</th>
                            <th class="text-end">股數</th>
                            <th class="text-end">購入日期</th>
                            <th class="text-end">購入成本/股</th>
                            <th class="text-end">總成本</th>
                            <th class="text-end">現在股價</th>
                            <th class="text-end">現值</th>
                            <th class="text-end">損益</th>
                            <th class="text-end">報酬率</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.Holdings)
                        {
                            <tr>
                                <td><strong>@h.Symbol</strong></td>
                                <td>@h.Name</td>
                                <td class="text-end">@h.Shares.ToString("N0")</td>
                                <td class="text-end">@h.PurchaseDate.ToString("yyyy/MM/dd")</td>
                                <td class="text-end">@h.PurchasePrice.ToString("N2")</td>
                                <td class="text-end">@h.TotalCost.ToString("N0")</td>
                                <td class="text-end">
                                    @if (h.CurrentPrice.HasValue)
                                    {
                                        @h.CurrentPrice.Value.ToString("N2")
                                    }
                                    else
                                    {
                                        <span class="text-muted small" title="@h.ErrorMessage">無法取得</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (h.CurrentValue.HasValue)
                                    {
                                        @h.CurrentValue.Value.ToString("N0")
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (h.PnL.HasValue)
                                    {
                                        <span class="@(h.PnL >= 0 ? "tw-gain" : "tw-loss") fw-semibold">
                                            @(h.PnL >= 0 ? "+" : "")@h.PnL.Value.ToString("N0")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (h.PnLPercent.HasValue)
                                    {
                                        <span class="@(h.PnLPercent >= 0 ? "tw-gain" : "tw-loss") fw-semibold">
                                            @(h.PnLPercent >= 0 ? "+" : "")@h.PnLPercent.Value.ToString("F2")%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-action="Chart" asp-route-symbol="@h.Symbol" asp-route-purchasePrice="@h.PurchasePrice"
                                           class="btn btn-sm btn-outline-primary">走勢圖</a>
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('確定要刪除 @h.Symbol 的持股紀錄？')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@h.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
