@{
    ViewData["Title"] = ViewBag.Symbol + " 走勢圖";
    var symbol = (string)ViewBag.Symbol;
    var purchasePrice = (decimal?)ViewBag.PurchasePrice;
}

<div class="flex items-center gap-3 mb-6">
    <a asp-action="Index"
       class="text-sm border border-white/25 text-white/70 rounded px-3 py-1.5 hover:bg-white/10 transition-colors">
        <i class="fa-solid fa-arrow-left mr-1"></i>返回庫存
    </a>
    <h1 class="text-2xl font-bold text-white" id="stockTitle">@symbol 走勢圖</h1>
</div>

<div class="glass rounded-xl">
    <div class="px-4 py-3 border-b border-white/15 rounded-t-xl flex flex-wrap justify-between items-center gap-2">
        <div class="inline-flex rounded-md overflow-hidden" role="group" aria-label="時間區間">
            <button type="button" class="range-btn rounded-l-md active" data-days="30">30天</button>
            <button type="button" class="range-btn" data-days="90">90天</button>
            <button type="button" class="range-btn" data-days="180">半年</button>
            <button type="button" class="range-btn rounded-r-md" data-days="365">一年</button>
        </div>
        <span id="chartStatus" class="text-white/50 text-sm"></span>
    </div>
    <div class="p-4">
        <div id="loadingSpinner" class="text-center py-16">
            <div class="inline-block h-10 w-10 animate-spin rounded-full border-4 border-solid border-white/20 border-t-white/80" role="status"></div>
            <div class="mt-3 text-white/50">載入資料中...</div>
        </div>
        <div id="errorMsg" class="hidden bg-yellow-500/20 border border-yellow-400/30 text-yellow-200 rounded-lg p-4"></div>
        <canvas id="priceChart" style="display:none; max-height:420px;"></canvas>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const symbol = '@symbol';
    const purchasePrice = @(purchasePrice.HasValue ? purchasePrice.Value.ToString() : "null");

    let chart = null;
    let allDates = [];
    let allPrices = [];

    function sliceLastDays(days) {
        if (allDates.length === 0) return { dates: [], prices: [] };
        const start = Math.max(0, allDates.length - days);
        return { dates: allDates.slice(start), prices: allPrices.slice(start) };
    }

    function renderChart(dates, prices) {
        const canvas = document.getElementById('priceChart');
        canvas.style.display = 'block';

        const datasets = [{
            label: '收盤價',
            data: prices,
            borderColor: 'rgba(147,197,253,0.9)',
            backgroundColor: 'rgba(147,197,253,0.08)',
            borderWidth: 2,
            pointRadius: dates.length > 100 ? 0 : 2,
            pointHoverRadius: 4,
            tension: 0.1,
            fill: true
        }];

        if (purchasePrice !== null) {
            datasets.push({
                label: `購入成本 ${purchasePrice.toLocaleString()}`,
                data: new Array(dates.length).fill(purchasePrice),
                borderColor: 'rgba(251,146,60,0.8)',
                borderWidth: 1.5,
                borderDash: [6, 4],
                pointRadius: 0,
                pointHoverRadius: 0,
                fill: false
            });
        }

        if (chart) chart.destroy();

        chart = new Chart(canvas, {
            type: 'line',
            data: { labels: dates, datasets },
            options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { color: 'rgba(255,255,255,0.7)' }
                    },
                    tooltip: {
                        callbacks: {
                            label: ctx => `${ctx.dataset.label}：${ctx.parsed.y.toLocaleString('zh-TW', { minimumFractionDigits: 2 })}`
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { maxTicksLimit: 8, maxRotation: 0, color: 'rgba(255,255,255,0.5)' },
                        grid: { color: 'rgba(255,255,255,0.08)' }
                    },
                    y: {
                        ticks: { callback: v => v.toLocaleString('zh-TW'), color: 'rgba(255,255,255,0.5)' },
                        grid: { color: 'rgba(255,255,255,0.08)' }
                    }
                }
            }
        });
    }

    function showRange(days) {
        const { dates, prices } = sliceLastDays(days);
        if (dates.length === 0) {
            document.getElementById('chartStatus').textContent = '此範圍無資料';
            return;
        }
        document.getElementById('chartStatus').textContent =
            `${dates[0]} ～ ${dates[dates.length - 1]}，共 ${dates.length} 個交易日`;
        renderChart(dates, prices);
    }

    async function loadAllData() {
        try {
            const resp = await fetch(`/Home/History?symbol=${encodeURIComponent(symbol)}`);
            const data = await resp.json();

            document.getElementById('loadingSpinner').hidden = true;

            if (data.error) {
                const errEl = document.getElementById('errorMsg');
                errEl.textContent = '無法取得資料：' + data.error;
                errEl.classList.remove('hidden');
                return;
            }

            allDates = data.dates.slice().reverse();
            allPrices = data.prices.slice().reverse();
            document.getElementById('stockTitle').textContent = `${data.name}（${data.symbol}）走勢圖`;

            showRange(30);

        } catch (e) {
            document.getElementById('loadingSpinner').hidden = true;
            const errEl = document.getElementById('errorMsg');
            errEl.textContent = '連線錯誤：' + e.message;
            errEl.classList.remove('hidden');
        }
    }

    document.querySelectorAll('.range-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            showRange(parseInt(this.dataset.days));
        });
    });

    loadAllData();
</script>
}
