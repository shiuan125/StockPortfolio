@model ErrorViewModel
@{
    ViewData["Title"] = "錯誤";
}

<h1 class="text-2xl font-bold text-red-400 mb-2">發生錯誤</h1>
<p class="text-red-300/80 mb-4">處理請求時發生問題。</p>

@if (Model.ShowRequestId)
{
    <p class="text-sm text-white/60 mb-4">
        <span class="font-medium">Request ID：</span>
        <code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">@Model.RequestId</code>
    </p>
}

<div class="glass bg-yellow-500/10 border-yellow-400/20 rounded-xl p-4 text-sm text-yellow-200/80">
    <p class="font-medium mb-1">開發模式</p>
    <p>將環境變數 <code class="bg-white/10 px-1 rounded">ASPNETCORE_ENVIRONMENT</code> 設為
       <code class="bg-white/10 px-1 rounded">Development</code> 並重啟應用程式，可顯示詳細錯誤資訊。</p>
    <p class="mt-2 font-medium">請勿在生產環境啟用 Development 模式，以免洩漏敏感資訊。</p>
</div>
