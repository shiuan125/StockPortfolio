<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockPortfolio</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="min-h-screen flex flex-col text-white">

    <!-- 背景漸層 + 裝飾光暈 -->
    <div class="fixed inset-0 -z-10 bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900"></div>
    <div class="fixed -z-10 top-[-15%] right-[-10%] w-[500px] h-[500px] bg-blue-600/25 rounded-full blur-3xl pointer-events-none"></div>
    <div class="fixed -z-10 bottom-[-15%] left-[-10%] w-[500px] h-[500px] bg-purple-600/25 rounded-full blur-3xl pointer-events-none"></div>
    <div class="fixed -z-10 top-[40%] left-[40%] w-[300px] h-[300px] bg-indigo-500/15 rounded-full blur-3xl pointer-events-none"></div>

    <header>
        <nav class="bg-white/10 backdrop-blur-md border-b border-white/15 shadow-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6">
                <div class="flex items-center h-14">
                    <a class="font-semibold text-white text-lg tracking-tight"
                       asp-controller="Home" asp-action="Index">StockPortfolio</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 flex-1">
        <main class="py-6">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-white/10 text-white/50 text-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
            &copy; 2026 - StockPortfolio
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
